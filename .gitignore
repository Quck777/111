```gitignore
# Build artifacts
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution / packaging
.Python
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.mypy_cache/
.tox/

# Local configuration
config/local_settings.py
settings_local.py

# Database
*.db
*.sqlite
*.sqlite3

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```